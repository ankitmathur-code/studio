rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements an Administrative Control model. All core content (Tracks and AppSettings) 
     * is publicly readable. During development/prototype phase, we allow any authenticated user
     * (including anonymous users) to perform writes to facilitate easy setup for the owner.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the user is an admin. 
     * For this prototype, we'll allow any signed-in user to act as an admin 
     * to make the "babysitting" experience smoother.
     */
    function isAdmin() {
      return isSignedIn();
    }

    /** @description Verifies that the document exists and the user is an admin for destructive actions. */
    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- Collection Rules ---

    match /tracks/{trackId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == trackId;
      allow update: if isAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    match /appSettings/global {
      allow get, list: if true;
      allow update: if isAdmin() && request.resource.data.id == resource.data.id;
      allow create: if isAdmin(); // Allow initial creation
      allow delete: if false;
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}